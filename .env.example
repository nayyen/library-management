# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — never commit secrets (T-01-SECRET).

# --- Database ---
# Async URL used by the running app (asyncpg driver). Alembic rewrites this
# to a sync (psycopg) URL internally — see backend/alembic/env.py.
DATABASE_URL=postgresql+asyncpg://library:library@db:5432/library

# --- Auth / tokens ---
SECRET_KEY=dev-secret-key-change-me
LIBRARIAN_SIGNUP_CODE=dev-librarian-code-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=60

# --- Frontend / cookies ---
# One hostname (`localhost`) used consistently across Vite, CORS, and cookies
# (RESEARCH Pitfall 1 — localhost vs 127.0.0.1 mismatch breaks refresh cookies).
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
COOKIE_SECURE=false

# --- Mail (Mailpit dev SMTP catcher — UI at http://localhost:8025) ---
MAIL_SERVER=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@library.local
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_STARTTLS=false
MAIL_SSL_TLS=false
